<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <system:String x:Key="R_STR_USERNAME">账号</system:String>
    <system:String x:Key="R_STR_PASSWORD">密码</system:String>
    <system:String x:Key="R_STR_LOGIN">登录</system:String>
    <system:String x:Key="R_STR_AUTO_LOGIN">自动登录</system:String>
    <system:String x:Key="R_STR_REMEMBER_ME">记住账号</system:String>
    <system:String x:Key="R_STR_OK">确定</system:String>
    <system:String x:Key="R_STR_CANCEL">取消</system:String>
    <system:String x:Key="R_STR_SETTING">设置</system:String>
    <system:String x:Key="R_STR_LANGUAGE">语言</system:String>
    <system:String x:Key="R_STR_THEME">主题</system:String>
    <system:String x:Key="R_STR_TEST_DELAY">测试延时</system:String>
    <system:String x:Key="R_STR_CONN_NAME">名称</system:String>
    <system:String x:Key="R_STR_ADDRESS">地址</system:String>
    <system:String x:Key="R_STR_DELAY_MS">延时(ms)</system:String>
    <system:String x:Key="R_STR_MENU">菜单</system:String>
    <system:String x:Key="R_STR_HOMEPAGE">主页</system:String>
    <system:String x:Key="R_STR_DEMO">示例</system:String>
    <system:String x:Key="R_STR_TEST">测试</system:String>
    <system:String x:Key="R_STR_DELETE_CONFIRM_NOTICE">确定要删除 `#1` 吗？</system:String>
    <system:String x:Key="R_STR_REMOVE_USER_DATA_NOTICE">是否同时删除用户数据？</system:String>
    <system:String x:Key="R_STR_CHANGE_CONN_NOTICE">若改变连接地址客户端将断开重连，是否继续？</system:String>
    <system:String x:Key="R_STR_NEW_VERSION_RELEASED">新版本已发布，请更新</system:String>
    <system:String x:Key="R_STR_UPDATE_FAILED_NOTICE">更新客户端失败，是否继续？</system:String>
    <system:String x:Key="R_STR_SYSTEM">系统</system:String>
    <system:String x:Key="R_STR_ENTER">进入</system:String>
    <system:String x:Key="R_STR_COLUMN">字段</system:String>
    <system:String x:Key="R_STR_COLUMNS">字段</system:String>
    <system:String x:Key="R_STR_DATABASES">数据库</system:String>
    <system:String x:Key="R_STR_TABLES">表</system:String>
    <system:String x:Key="R_STR_APIS">API</system:String>
    <system:String x:Key="R_STR_SAVE">保存</system:String>
    <system:String x:Key="R_STR_RESTORE">还原</system:String>
    <system:String x:Key="R_STR_ADD">新增</system:String>
    <system:String x:Key="R_STR_MODIFY">修改</system:String>
    <system:String x:Key="R_STR_DELETE">删除</system:String>
    <system:String x:Key="R_STR_EDIT">编辑</system:String>
    <system:String x:Key="R_STR_NAME">名称</system:String>
    <system:String x:Key="R_STR_DESCRIPTION">说明</system:String>
    <system:String x:Key="R_STR_TYPE">类型</system:String>
    <system:String x:Key="R_STR_LENGTH">长度</system:String>
    <system:String x:Key="R_STR_PRECISION">精度</system:String>
    <system:String x:Key="R_STR_SCALE">小数位数</system:String>
    <system:String x:Key="R_STR_MAX_BYTES_PER_CHAR">字符最大字节数</system:String>
    <system:String x:Key="R_STR_IS_NULLABLE">可空</system:String>
    <system:String x:Key="R_STR_DEFAULT_VALUE">缺省值</system:String>
    <system:String x:Key="R_STR_DATA_DICT">数据字典</system:String>
    <system:String x:Key="R_STR_REMARK">备注</system:String>
    <system:String x:Key="R_STR_GROUP">分组</system:String>
    <system:String x:Key="R_STR_NEW_ADD">新增...</system:String>
    <system:String x:Key="R_STR_VALUE">值</system:String>
    <system:String x:Key="R_STR_MEANING">含意</system:String>
    <system:String x:Key="R_STR_ADD_GROUP">新增分组</system:String>
