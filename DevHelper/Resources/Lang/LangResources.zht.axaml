<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <system:String x:Key="R_STR_USERNAME">賬號</system:String>
    <system:String x:Key="R_STR_PASSWORD">密碼</system:String>
    <system:String x:Key="R_STR_LOGIN">登錄</system:String>
    <system:String x:Key="R_STR_AUTO_LOGIN">自動登錄</system:String>
    <system:String x:Key="R_STR_REMEMBER_ME">記住帳號</system:String>
    <system:String x:Key="R_STR_OK">確定</system:String>
    <system:String x:Key="R_STR_CANCEL">取消</system:String>
    <system:String x:Key="R_STR_SETTING">設置</system:String>
    <system:String x:Key="R_STR_LANGUAGE">語言</system:String>
    <system:String x:Key="R_STR_THEME">主題</system:String>
    <system:String x:Key="R_STR_TEST_DELAY">測試延時</system:String>
    <system:String x:Key="R_STR_CONN_NAME">名稱</system:String>
    <system:String x:Key="R_STR_ADDRESS">地址</system:String>
    <system:String x:Key="R_STR_DELAY_MS">延時(ms)</system:String>
    <system:String x:Key="R_STR_MENU">菜單</system:String>
    <system:String x:Key="R_STR_HOMEPAGE">主頁</system:String>
    <system:String x:Key="R_STR_DEMO">示例</system:String>
    <system:String x:Key="R_STR_TEST">測試</system:String>
    <system:String x:Key="R_STR_DELETE_CONFIRM_NOTICE">確定要刪除 [#1] 嗎？</system:String>
    <system:String x:Key="R_STR_REMOVE_USER_DATA_NOTICE">是否同時刪除用戶數據？</system:String>
    <system:String x:Key="R_STR_CHANGE_CONN_NOTICE">若改變連接地址客戶端將斷開重連，是否繼續？</system:String>
    <system:String x:Key="R_STR_NEW_VERSION_RELEASED">新版本已發佈，請更新</system:String>
    <system:String x:Key="R_STR_UPDATE_FAILED_NOTICE">更新客戶端失敗，是否繼續？</system:String>
    <system:String x:Key="R_STR_SYSTEM">系統</system:String>
    <system:String x:Key="R_STR_ENTER">進入</system:String>
    <system:String x:Key="R_STR_COLUMN">字段</system:String>
    <system:String x:Key="R_STR_COLUMNS">字段</system:String>
    <system:String x:Key="R_STR_TABLES">表</system:String>
    <system:String x:Key="R_STR_SAVE">保存</system:String>
    <system:String x:Key="R_STR_RESTORE">還原</system:String>
    <system:String x:Key="R_STR_ADD">新增</system:String>
    <system:String x:Key="R_STR_MODIFY">修改</system:String>
    <system:String x:Key="R_STR_DELETE">刪除</system:String>
    <system:String x:Key="R_STR_EDIT">編輯</system:String>
    <system:String x:Key="R_STR_NAME">名稱</system:String>
    <system:String x:Key="R_STR_DESCRIPTION">說明</system:String>
    <system:String x:Key="R_STR_TYPE">類型</system:String>
    <system:String x:Key="R_STR_LENGTH">長度</system:String>
    <system:String x:Key="R_STR_PRECISION">精度</system:String>
    <system:String x:Key="R_STR_SCALE">小數位數</system:String>
    <system:String x:Key="R_STR_MAX_BYTES_PER_CHAR">字符最大字節數</system:String>
    <system:String x:Key="R_STR_IS_NULLABLE">可空</system:String>
    <system:String x:Key="R_STR_DEFAULT_VALUE">缺省值</system:String>
    <system:String x:Key="R_STR_DATA_DICT">數據字典</system:String>
    <system:String x:Key="R_STR_REMARK">備註</system:String>
    <system:String x:Key="R_STR_GROUP">分組</system:String>
    <system:String x:Key="R_STR_NEW_ADD">新增...</system:String>
    <system:String x:Key="R_STR_VALUE">值</system:String>
    <system:String x:Key="R_STR_MEANING">含意</system:String>
    <system:String x:Key="R_STR_ADD_GROUP">新增分組</system:String>
    <system:String x:Key="R_STR_ADD_DATABASE">新增數據庫</system:String>
    <system:String x:Key="R_STR_ADD_TABLE">新增表</system:String>
    <system:String x:Key="R_STR_BASIC_INFO">基本資訊</system:String>
    <system:String x:Key="R_STR_HISTORY_TABLE">歷史表</system:String>
    <system:String x:Key="R_STR_HAS_HISTORY_TABLE">有歷史表</system:String>
    <system:String x:Key="R_STR_NOT_HAS_HISTORY_TABLE">無歷史表</system:String>
    <system:String x:Key="R_STR_PRIMARY_KEY">主鍵</system:String>
    <system:String x:Key="R_STR_INDEXES">索引</system:String>
    <system:String x:Key="R_STR_FOREIGN_KEYS">外鍵</system:String>
    <system:String x:Key="R_STR_REFERENCE_TABLE">指向表</system:String>
    <system:String x:Key="R_STR_REFERENCE_COLUMN">指向字段</system:String>
    <system:String x:Key="R_STR_GROUP_NAME_EXIST_NOTICE">分組名稱已存在</system:String>
    <system:String x:Key="R_STR_NAME_EXIST_NOTICE">名稱已存在</system:String>
    <system:String x:Key="R_STR_EMPTY_NAME_NOTICE">名稱為空</system:String>
    <system:String x:Key="R_STR_SELECT_EMPTY_COLUMN_NOTICE">請選擇字段</system:String>
    <system:String x:Key="R_STR_SELECT_EMPTY_REFERENCE_TABLE_NOTICE">請選擇參照表</system:String>
    <system:String x:Key="R_STR_SELECT_EMPTY_REFERENCE_COLUMN_NOTICE">請選擇參照字段</system:String>
    <system:String x:Key="R_STR_FOREIGN_KEY_COLUMN_TYPE_INCONSISTENT_NOTICE">字段類型 [#1] 與參照字段類型 [#2] 不一致</system:String>
    <system:String x:Key="R_STR_SELECT_EMPTY_INDEX_NOTICE">請選擇索引</system:String>
    <system:String x:Key="R_STR_DELETE_COLUMNS_CONFIRM_NOTICE">確認刪除以下字段？</system:String>
    <system:String x:Key="R_STR_MODIFIED_COLUMN_IS_USED_BY_TABLE_NOTICE">字段 [#1] 被表 [#2] 使用，仍然修改？</system:String>
    <system:String x:Key="R_STR_DELETED_COLUMN_IS_USED_BY_TABLE_NOTICE">字段 [#1] 被表 [#2] 使用</system:String>
    <system:String x:Key="R_STR_DELETED_COLUMN_IS_USED_BY_TABLE_AND_RESERVED_NOTICE">字段 [#1] 被表 [#2] 使用，因此將被保留</system:String>
    <system:String x:Key="R_STR_COLUMN_IS_USED_BY_INDEX_NOTICE">字段 [#1] 被索引 [#2] 使用</system:String>
    <system:String x:Key="R_STR_COLUMN_NOT_FOUND_NOTICE">找不到字段信息 [#1]</system:String>
    <system:String x:Key="R_STR_COLUMN_DEFAULT_VALUE_NOT_MATCH_TYPE">缺省值與字段類型不一致</system:String>
    <system:String x:Key="R_STR_ADD_FAILED">新增失敗</system:String>
    <system:String x:Key="R_STR_DELETE_FAILED">刪除失敗</system:String>
    <system:String x:Key="R_STR_MODIFY_FAILED">修改失敗</system:String>
    <system:String x:Key="R_STR_SAVE_SUCCESS">保存成功</system:String>
    <system:String x:Key="R_STR_SAVE_FAILED">保存失敗</system:String>

</ResourceDictionary>
