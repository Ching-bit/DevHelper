<frw:UniPanel
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ursa="https://irihi.tech/ursa"
    xmlns:frw="clr-namespace:Framework.Common;assembly=Framework.Common"
    xmlns:local="clr-namespace:UniClient"
    x:Class="UniClient.MainView"
    x:Name="This">
    
    <frw:UniPanel.Resources>
        <local:NavContextMenuDisplayConverter x:Key="NavContextMenuDisplayConverter"/>
    </frw:UniPanel.Resources>
    
    <Grid ColumnDefinitions="Auto,*">
        <!-- Left Nav -->
        <Border
            Padding="0"
            HorizontalAlignment="Left"
            Theme="{DynamicResource CardBorder}">
            <ursa:NavMenu
                x:Name="NavMenu"
                DataContext="{Binding ElementName=This, Path=DataContext}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CollapseWidth="50"
                IsHorizontalCollapsed="False"
                ItemsSource="{Binding Menus}"
                SelectedItem="{Binding SelectedMenu}"
                SubMenuBinding="{Binding SubMenus}"
                HeaderBinding="{Binding Name}"
                IconBinding="{Binding .}"
                Classes="enable_animation">
                <ursa:NavMenu.Header>
                    <PathIcon
                        Data="{StaticResource SemiIconMenu}"
                        Classes="Common Large"
                        Width="{Binding ElementName=NavMenu, Path=ExpandWidth}"
                        ursa:NavMenu.CanToggle="True"/>
                </ursa:NavMenu.Header>
                <ursa:NavMenu.IconTemplate>
                    <DataTemplate DataType="{x:Type local:MenuConfModel}">
                        <Grid>
                            <!-- Columns menu icon -->
                            <PathIcon Data="{StaticResource SemiIconGridSquare}" Classes="Common">
                                <PathIcon.IsVisible>
                                    <MultiBinding Converter="{StaticResource BoolAndConverter}">
                                        <Binding ElementName="NavMenu" Path="IsHorizontalCollapsed" Converter="{StaticResource BoolReverseConverter}"/>
                                        <Binding Path="MenuType" Converter="{StaticResource IsValueInConverter}" ConverterParameter="Columns"/>
                                    </MultiBinding>
                                </PathIcon.IsVisible>
                            </PathIcon>
                            <!-- Tables menu icon -->
                            <PathIcon Data="{StaticResource SemiIconServer}" Classes="Common">
                                <PathIcon.IsVisible>
                                    <MultiBinding Converter="{StaticResource BoolAndConverter}">
                                        <Binding ElementName="NavMenu" Path="IsHorizontalCollapsed" Converter="{StaticResource BoolReverseConverter}"/>
                                        <Binding Path="MenuType" Converter="{StaticResource IsValueInConverter}" ConverterParameter="Tables"/>
                                    </MultiBinding>
                                </PathIcon.IsVisible>
                            </PathIcon>
                            <!-- icon when collapsed -->
                            <Border Theme="{DynamicResource CardBorder}"
                                    Padding="2" Margin="0" MinHeight="25" MinWidth="25">
                                <Border.IsVisible>
                                    <MultiBinding Converter="{StaticResource BoolAndConverter}">
                                        <Binding ElementName="NavMenu" Path="IsHorizontalCollapsed"/>
                                        <Binding Path="MenuLevel" Converter="{StaticResource NumberEqualsConverter}" ConverterParameter='1'/>
                                    </MultiBinding>
                                </Border.IsVisible>
                                <TextBlock
                                    Text="{Binding Name, Converter={StaticResource SubStringConverter}, ConverterParameter='0,1'}"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ursa:NavMenu.IconTemplate>
                
                <!-- Right Click Menu -->
                <ursa:NavMenu.Styles>
                    <Style Selector="ursa|NavMenuItem">
                        <Setter Property="ContextMenu">
                            <MultiBinding Converter="{StaticResource NavContextMenuDisplayConverter}">
                                <Binding Path="IsAddGroupVisible"/>
                                <Binding Path="IsAddVisible"/>
                                <Binding Path="IsModifyVisible"/>
                                <Binding Path="IsDeleteVisible"/>
                                <MultiBinding.ConverterParameter>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource R_STR_ADD_GROUP}"
                                                  IsVisible="{Binding IsAddGroupVisible}"
                                                  Command="{Binding #This.DataContext.AddGroupCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="{DynamicResource R_STR_ADD}"
                                                  IsVisible="{Binding IsAddVisible}"
                                                  Command="{Binding #This.DataContext.AddItemCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <MenuItem Header="{DynamicResource R_STR_MODIFY}"
                                                  IsVisible="{Binding IsModifyVisible}"/>
                                        <MenuItem Header="{DynamicResource R_STR_DELETE}"
                                                  IsVisible="{Binding IsDeleteVisible}"/>
                                    </ContextMenu>
                                </MultiBinding.ConverterParameter>
                            </MultiBinding>
                        </Setter>
                    </Style>
                </ursa:NavMenu.Styles>
            </ursa:NavMenu>
        </Border>
        
        <!-- Right -->
        <DockControl Grid.Column="1" x:Name="DockControl" InitializeLayout="True" InitializeFactory="True">
            <DockControl.Factory>
                <Factory/>
            </DockControl.Factory>
            <RootDock IsCollapsable="False" DefaultDockable="{Binding #MainLayout}">
                <ProportionalDock Id="MainLayout" Orientation="Horizontal">
                    <ProportionalDock>
                        <DocumentDock x:Name="MenuDock" CanCreateDocument="False" CanDrag="False" CanDrop="False">
                            <Document CanClose="False">
                                <local:HomeView/>
                            </Document>
                        </DocumentDock>
                    </ProportionalDock>
                </ProportionalDock>
            </RootDock>
        </DockControl>
    </Grid>
</frw:UniPanel>
