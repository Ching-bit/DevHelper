<frw:UniMenu
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:frw="clr-namespace:Framework.Common;assembly=Framework.Common"
    x:Class="Menu.DevData.ColumnsView">
    
    <Grid RowDefinitions="Auto,*">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20">
            <Button Classes="Common Primary" Content="{DynamicResource R_STR_SAVE}"/>
            <Button Classes="Common Success" Content="{DynamicResource R_STR_RESTORE}"/>
            <Button Classes="Common" Content="{DynamicResource R_STR_ADD}" Command="{Binding AddColumnCommand}"/>
            <Button Classes="Common" Content="{DynamicResource R_STR_MODIFY}"/>
            <Button Classes="Common Danger" Content="{DynamicResource R_STR_DELETE}"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ColumnListView}"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <!-- ID -->
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    IsReadOnly="True"/>
                <!-- Name -->
                <DataGridTextColumn Header="{DynamicResource R_STR_NAME}"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True" Width="150"/>
                <!-- Description -->
                <DataGridTextColumn Header="{DynamicResource R_STR_DESCRIPTION}"
                                    Binding="{Binding Description}"
                                    IsReadOnly="True" Width="150"/>
                <!-- Type -->
                <DataGridTextColumn Header="{DynamicResource R_STR_TYPE}"
                                    Binding="{Binding ColumnTypes}"
                                    IsReadOnly="True" Width="110"/>
                <!-- Length -->
                <DataGridTextColumn Header="{DynamicResource R_STR_LENGTH}"
                                    Binding="{Binding Length}"
                                    IsReadOnly="True" Width="80"/>
                <!-- Scale -->
                <DataGridTextColumn Header="{DynamicResource R_STR_SCALE}"
                                    Binding="{Binding Scale}"
                                    IsReadOnly="True" Width="80"/>
                <!-- DataDict -->
                <DataGridTextColumn Header="{DynamicResource R_STR_DATA_DICT}"
                                    Binding="{Binding DataDict}"
                                    IsReadOnly="True" Width="300"/>
                <!-- Remark -->
                <DataGridTextColumn Header="{DynamicResource R_STR_REMARK}"
                                    Binding="{Binding Remark}"
                                    IsReadOnly="True" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
        
    </Grid>
    
</frw:UniMenu>
