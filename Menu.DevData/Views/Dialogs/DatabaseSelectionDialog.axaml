<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ursa="https://irihi.tech/ursa"
    xmlns:ctrl="clr-namespace:Control.Basic;assembly=Control.Basic"
    x:Class="Menu.DevData.DatabaseSelectionDialog">
    
    <ctrl:ConfirmDialog ReturnParameter="{Binding TargetDatabases}">
        <HeaderedContentControl Header="{DynamicResource R_STR_DATABASES}" Classes="Common">
            <ursa:MultiComboBox
                Classes="Common"
                ItemsSource="{Binding DatabaseList}"
                SelectedItems="{Binding TargetDatabases}"
                ToolTip.Tip="{DynamicResource R_STR_EMPTY_MEANS_ALL}"/>
        </HeaderedContentControl>
    </ctrl:ConfirmDialog>
    
</UserControl>
