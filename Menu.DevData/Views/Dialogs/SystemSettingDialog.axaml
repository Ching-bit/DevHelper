<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Control.Basic;assembly=Control.Basic"
    x:Class="Menu.DevData.SystemSettingDialog">
    
    <ctrl:ConfirmDialog ReturnParameter="{Binding SystemSettingModel}">
        <StackPanel>
            <!-- history database name -->
            <HeaderedContentControl Classes="Common" Header="{DynamicResource R_STR_HIS_DB_NAME}">
                <TextBox Classes="Common" Width="300"
                         Text="{Binding SystemSettingModel.HistoryDatabaseName}"/>
            </HeaderedContentControl>
            <!-- history table name -->
            <HeaderedContentControl Classes="Common" Header="{DynamicResource R_STR_HIS_TABLE_NAME}">
                <TextBox Classes="Common" Width="300"
                         Text="{Binding SystemSettingModel.HistoryTableName}"/>
            </HeaderedContentControl>
            <!-- data column name of history tables -->
            <HeaderedContentControl Classes="Common" Header="{DynamicResource R_STR_HIS_TABLE_DATE_COLUMN_NAME}">
                <TextBox Classes="Common" Width="300"
                         Text="{Binding SystemSettingModel.ArchiveDateColumnName}"/>
            </HeaderedContentControl>
        </StackPanel>
    </ctrl:ConfirmDialog>
    
</UserControl>
