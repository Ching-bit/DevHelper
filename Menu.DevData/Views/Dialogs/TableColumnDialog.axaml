<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ursa="https://irihi.tech/ursa"
    xmlns:ctrl="clr-namespace:Control.Basic;assembly=Control.Basic"
    x:Class="Menu.DevData.TableColumnDialog">
    
    <ctrl:ConfirmDialog ReturnParameter="{Binding SelectedColumn}">
        <HeaderedContentControl Classes="Common" Header="{DynamicResource R_STR_COLUMN}">
            <ursa:AutoCompleteBox
                Classes="Common" FilterMode="Contains"
                ItemsSource="{Binding AllColumns}"
                SelectedItem="{Binding SelectedColumn}"
                Width="300"/>
        </HeaderedContentControl>
    </ctrl:ConfirmDialog>
    
</UserControl>
