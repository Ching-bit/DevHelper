<frw:UniPanel
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:frw="clr-namespace:Framework.Common;assembly=Framework.Common"
    x:Class="Menu.DevData.TableBasicInfoPanel"
    x:Name="This">
    
    <StackPanel HorizontalAlignment="Left">
        <HeaderedContentControl Header="{DynamicResource R_STR_NAME}" Classes="Common">
            <TextBlock Text="{Binding ElementName=This, Path=TableInfoModel.Name}" Margin="5,0,0,0"/>
        </HeaderedContentControl>
        <HeaderedContentControl Header="{DynamicResource R_STR_DESCRIPTION}" Classes="Common">
            <TextBlock Text="{Binding ElementName=This, Path=TableInfoModel.Description}" Margin="5,0,0,0"/>
        </HeaderedContentControl>
    </StackPanel>
    
</frw:UniPanel>
