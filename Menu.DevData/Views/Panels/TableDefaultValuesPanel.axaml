<frw:UniPanel
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:frw="clr-namespace:Framework.Common;assembly=Framework.Common"
    x:Class="Menu.DevData.TableDefaultValuesPanel">
    
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Classes="Common Success"
                    Content="{DynamicResource R_STR_ADD}"
                    Command="{Binding AddRowCommand, RelativeSource={RelativeSource AncestorType=frw:UniPanel}}"/>
            <Button Classes="Common Danger"
                    Content="{DynamicResource R_STR_DELETE}"
                    Command="{Binding DeleteRowCommand, RelativeSource={RelativeSource AncestorType=frw:UniPanel}}"/>
        </StackPanel>
        <DataGrid
            Grid.Row="1" x:Name="DataGridDefaultValues" AutoGenerateColumns="False"
            ItemsSource="{Binding DefaultValues, RelativeSource={RelativeSource AncestorType=frw:UniPanel}, Mode=TwoWay}"/>
    </Grid>
    
</frw:UniPanel>
