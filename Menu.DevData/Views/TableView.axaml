<frw:UniMenu
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ursa="https://irihi.tech/ursa"
    xmlns:frw="clr-namespace:Framework.Common;assembly=Framework.Common"
    xmlns:local="clr-namespace:Menu.DevData"
    x:Class="Menu.DevData.TableView">
    
    <Grid RowDefinitions="Auto,*">
        
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Classes="Common"
                    Content="{DynamicResource R_STR_SAVE}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsTableChanged}"/>
            <Button Classes="Common"
                    Content="{DynamicResource R_STR_RESTORE}"
                    Command="{Binding RestoreCommand}"
                    IsEnabled="{Binding IsTableChanged}"/>
        </StackPanel>
        
        <TabControl Grid.Row="1">
            <TabItem Header="{DynamicResource R_STR_BASIC_INFO}">
                <local:TableBasicInfoPanel
                    TableName="{Binding TableInfoModel.Name}"
                    TableDescription="{Binding TableInfoModel.Description}"
                    HasHistoryTable="{Binding TableInfoModel.HasHistoryTable, Mode=TwoWay}"
                    Remark="{Binding TableInfoModel.Remark, Mode=TwoWay}"
                    IsBasicInfoChanged="{Binding IsTableChanged, Mode=TwoWay}"/>
            </TabItem>
            <TabItem Header="{DynamicResource R_STR_COLUMNS}">
                <local:TableColumnsPanel
                    x:Name="TableColumnsPanel"
                    ColumnList="{Binding TableInfoModel.ColumnList}"
                    IsColumnChanged="{Binding IsTableChanged, Mode=TwoWay}"
                    IndexList="{Binding ElementName=TableIndexesPanel, Path=IndexList}"/>
            </TabItem>
            <TabItem Header="{DynamicResource R_STR_INDEXES}">
                <local:TableIndexesPanel
                    x:Name="TableIndexesPanel"
                    IndexList="{Binding TableInfoModel.IndexList}"
                    ColumnList="{Binding ElementName=TableColumnsPanel, Path=ColumnList}"
                    IsIndexChanged="{Binding IsTableChanged, Mode=TwoWay}"
                    TableName="{Binding TableInfoModel.Name}"/>
            </TabItem>
            <TabItem Header="{DynamicResource R_STR_FOREIGN_KEYS}">
                <local:TableForeignKeysPanel
                    ForeignKeyList="{Binding TableInfoModel.ForeignKeyList}"
                    ColumnList="{Binding ElementName=TableColumnsPanel, Path=ColumnList}"
                    IsForeignKeyChanged="{Binding IsTableChanged, Mode=TwoWay}"
                    TableName="{Binding TableInfoModel.Name}"/>
            </TabItem>
        </TabControl>
        
    </Grid>
    
</frw:UniMenu>
